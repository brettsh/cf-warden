# cf-warden settings
# Copy to settings.conf and fill in your values.
# Format: KEY=VALUE, one per line. Comments start with #.

# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to true to simulate mode switches without calling the Cloudflare API.
# State, scoring, and alerts all behave normally — only the CF API call is
# skipped. Safe to use on dev servers sharing the same settings.conf.
DRY_RUN=false

# ── Cloudflare ────────────────────────────────────────────────────────────────
CF_ZONE_ID=your-zone-id
CF_API_TOKEN=your-api-token
CF_ATTACK_MODE=under_attack
CF_NORMAL_MODE=medium

# ── Site ──────────────────────────────────────────────────────────────────────
# Used in alert email subjects. Defaults to CF_ZONE_ID if not set.
SITE_NAME=example.com

# ── Email Alerts ──────────────────────────────────────────────────────────────
EMAIL_ENABLED=true
EMAIL_TO=you@example.com
EMAIL_FROM=alerts@example.com
# SMTP settings are optional. If omitted, sends via the local sendmail binary.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=user@example.com
# SMTP_PASSWORD=yourpassword

# ── Scoring: CPU Load ─────────────────────────────────────────────────────────
# score contribution = int(load1 / LOAD_SCORE_DIVISOR)
# e.g. load=17 + 877 reqs → 101 pts (triggers); load=25 alone → 92 pts (safe)
LOAD_SCORE_DIVISOR=0.27
LOAD_LOW_THRESHOLD=4

# ── Scoring: Request Rate ─────────────────────────────────────────────────────
# score contribution = int(requests / REQ_SCORE_DIVISOR)
# e.g. 1000 req/60s → 40 pts; 2500 req/60s → 100 pts (triggers alone)
REQ_SCORE_DIVISOR=25
ACCESS_LOG_PATH=/var/log/nginx/access.log
ACCESS_LOG_WINDOW_SEC=60

# ── Trigger Behaviour ─────────────────────────────────────────────────────────
SCORE_TRIGGER=100
SCORE_CONFIRM_COUNT=1
COOLDOWN_SEC=300
ALERT_COOLDOWN_SEC=300

# ── Paths and Logging ─────────────────────────────────────────────────────────
STATE_DIR=/var/tmp/cf-warden
LOG_FILE=/var/log/cf-warden.log
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3
